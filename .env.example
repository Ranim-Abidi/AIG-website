# Copy this file to .env and fill in real values. Never commit .env to git.
# Rotate any credentials that were previously stored in source code.

# --- Local development ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000,http://127.0.0.1:5173,http://127.0.0.1:3000,http://127.0.0.1:8000
CSRF_TRUSTED_ORIGINS=
SECURE_SSL_REDIRECT=False
BEHIND_PROXY=False

# --- Production (https://newsite.aiesec.gr/) — use these on the server ---
# DJANGO_DEBUG=False
# DJANGO_SECRET_KEY=generate-a-new-long-random-secret
# DJANGO_ALLOWED_HOSTS=newsite.aiesec.gr
# CORS_ALLOWED_ORIGINS=https://newsite.aiesec.gr
# CSRF_TRUSTED_ORIGINS=https://newsite.aiesec.gr
# SECURE_SSL_REDIRECT=True
# BEHIND_PROXY=True

# --- EXPA ---
EXPA_API_TOKEN=
EXPA_VERIFY_SSL=True

# --- Podio ---
PODIO_CLIENT_ID=
PODIO_CLIENT_SECRET=
PODIO_USERNAME=
PODIO_PASSWORD=
PODIO_MEMBER_APP_TOKEN=
